#!/usr/bin/env bash
# trigger schedule: 発火時の実処理。スケジューラから wsl.exe 経由で呼ばれる。
# 責務は「halo CLI を正しい環境で呼ぶ」ことだけ（トリガー種別の分岐は持たない）。
# 引数: $1 = プロファイル名（例 nightly）。stdin JSON は持たない（D1 §1.9）。
set -euo pipefail

PROFILE="${1:?profile name required}"

# Windows パス継承問題の回避: PATH を Linux 側のみに洗い直す（設計 04 §4.2 / §7）。
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

# 無人実行では npx を経由せず .bin の絶対パスを直接叩く（バージョン固定・ネット非依存, D1 §1.9）。
# HALO_HOME 配下の node_modules/.bin/halo を唯一の起動入口とする。
HALO_HOME="${HALO_HOME:-$HOME/halo}"
HALO_BIN="${HALO_BIN:-$HALO_HOME/node_modules/.bin/halo}"

if [[ ! -x "$HALO_BIN" ]]; then
  echo "trigger-schedule/fire: halo CLI が見つかりません: $HALO_BIN" >&2
  exit 1
fi

exec "$HALO_BIN" run "$PROFILE"
