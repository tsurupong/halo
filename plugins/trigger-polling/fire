#!/usr/bin/env bash
# trigger polling: 高頻度発火時の実処理。schedule と同一の fire 契約に従う。
# ready タスク 0 件なら task-source が {"task_id":null} を返し core が即 exit 0 するため、
# 空振りのコストは小さい（設計 04 §4.4）。トリガー種別の分岐は持たない。
# 引数: $1 = プロファイル名（例 continuous）。stdin JSON は持たない（D1 §1.9）。
set -euo pipefail

PROFILE="${1:?profile name required}"

# Windows パス継承問題の回避: PATH を Linux 側のみに洗い直す（設計 04 §4.2 / §7）。
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$HOME/.local/bin${HALO_PATH_EXTRA:+:$HALO_PATH_EXTRA}"

# 無人実行では .bin の絶対パスを直接叩く（バージョン固定・ネット非依存, D1 §1.9）。
HALO_HOME="${HALO_HOME:-$HOME/halo}"
HALO_BIN="${HALO_BIN:-$HALO_HOME/node_modules/.bin/halo}"

if [[ ! -x "$HALO_BIN" ]]; then
  echo "trigger-polling/fire: halo CLI が見つかりません: $HALO_BIN" >&2
  exit 1
fi

exec "$HALO_BIN" run "$PROFILE" --cwd "$HALO_HOME"
